## 🔔 Alert Engine (Sample)

```python
# alert_engine.py
import re

PATTERNS = {
    "ssh_brute_force": r"Failed password.*from (\d+\.\d+\.\d+\.\d+)",
    "sudo_escalation": r"sudo.*authentication failure",
    "log_tampering":   r"rm.*auth\.log|truncate.*syslog",
}

def analyze_log(log_line):
    for alert_name, pattern in PATTERNS.items():
        if re.search(pattern, log_line, re.IGNORECASE):
            return {"alert": alert_name, "line": log_line.strip()}
    return None
```

