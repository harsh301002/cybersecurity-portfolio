## 🔧 Sample Hardening Script (Excerpt)

```bash
#!/bin/bash
# harden_linux.sh — CIS Benchmark Level 1 Hardening

echo "[*] Disabling root SSH login..."
sed -i 's/^PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config

echo "[*] Setting SSH max auth tries..."
sed -i 's/^#MaxAuthTries.*/MaxAuthTries 3/' /etc/ssh/sshd_config

echo "[*] Enabling UFW with deny-by-default..."
ufw default deny incoming
ufw default deny outgoing
ufw allow out 443/tcp
ufw allow out 80/tcp
ufw allow in 22/tcp
ufw --force enable

echo "[*] Disabling unused services..."
for svc in telnet rsh rlogin ftp cups avahi-daemon; do
    systemctl disable $svc 2>/dev/null
    systemctl stop $svc 2>/dev/null
done

echo "[+] Hardening complete. Run audit_check.sh to verify."
```

